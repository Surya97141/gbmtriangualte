  "operationCountRule": {
    "description": "Always calculate ACTUAL operation count before deciding feasibility",
    "formula": "actualOps = f(n) where f is your complexity class evaluated at your specific n",
    "examples": [
      { "scenario": "n=10^5, O(n log n)",                "calculation": "10^5 * 17 = 1.7 * 10^6",  "verdict": "Safe (0.017s)" },
      { "scenario": "n=10^5, q=10^5, O(q log n)/query",  "calculation": "10^5 * 17 = 1.7 * 10^6",  "verdict": "Safe" },
      { "scenario": "n=10^5, q=10^5, O(q * n)",          "calculation": "10^5 * 10^5 = 10^10",      "verdict": "Hard TLE (100s)" },
      { "scenario": "n=500, O(n^3)",                      "calculation": "500^3 = 1.25 * 10^8",      "verdict": "Borderline — risky at 1s, ok at 2s" }
