      "state_archetypes": "ontology/state-graph.json",
      "invariants": "ontology/invariant-graph.json",
      "misconceptions": "ontology/misconception-graph.json"
    },
    "edge_types": {
      "implies": "Signal is evidence for a target StateArchetype. Weight encodes inference strength 0.0-1.0.",
      "strengthens": "Signal raises confidence that a target Invariant holds. Weight encodes degree 0.0-1.0.",
      "contradicts": "Presence of source makes target inapplicable or reduces its aggregate weight. Target may be Signal or StateArchetype.",
      "breaks": "Presence of source makes target Invariant impossible to maintain. Hard invalidation. Weight is always 1.0.",
      "requires_also": "Stored on node. This signal is downweighted by 0.5 if any listed co-requisite signal is absent from the active signal set."
    }
  },
